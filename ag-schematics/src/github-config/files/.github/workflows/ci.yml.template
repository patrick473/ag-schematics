name: CI

on:
  push:
    branches:
      - <%= defaultBranch %>
  pull_request:
    branches:
      - <%= defaultBranch %>

jobs:
  build-and-test:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '<%= nodeVersion %>'

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build

      - name: Test
        run: npm test
